# Default configuration for ralph_coach_player.sh
#
# Usage:
#   cp .env.example .env
#   # edit .env as you like
#   ./ralph_coach_player.sh /path/to/project 100
#
# Environment variables you pass on the command line always win over .env values,
# so you can still do:
#   MODEL=opencode/other-model ./ralph_coach_player.sh /path/to/project
#
# .env lives next to this script (ralph_loop/coach_player/.env) and is loaded
# automatically. It is git-ignored.

# --- Models ---

# opencode model for Player (the implementer)
MODEL=opencode/big-pickle

# opencode model for Coach (the reviewer). Leave unset to reuse MODEL.
# COACH_MODEL=opencode/smarter-model

# --- Loop safety ---

# Retries on opencode run failure (network, empty output, non-zero exit).
# Exponential backoff: 5s -> 15s -> 45s.
MAX_RETRIES=3

# Halt the loop if HEAD does not move for this many consecutive iterations.
# Exits with code 3 when tripped.
MAX_NO_PROGRESS_TURNS=5

# Halt the loop if Coach reverts the same user story this many times in a row.
# Exits with code 2 when tripped (stable dispute — needs a human).
MAX_REVERTS_PER_US=3
